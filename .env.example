# Slack Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Channel IDs (right-click channel → View channel details → ID at bottom)
FREE_CHANNEL_ID=C0123456789
PAID_CHANNEL_ID=C9876543210

# Your Slack user ID (click profile → three-dot menu → Copy member ID)
REPORT_USER_ID=U0011223344

# Cron schedule (default: 9:00 AM weekdays)
CRON_SCHEDULE=0 9 * * 1-5

# Timezone
CRON_TIMEZONE=America/New_York
TZ=America/New_York
